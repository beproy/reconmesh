# === Secrets & environment files ===
# NEVER commit anything matching these patterns
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.pfx
*.p12
secrets/
credentials/

# === Python (backend) ===
__pycache__/
*.py[cod]
*.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# === Node / React (frontend) ===
node_modules/
dist/
build/
.next/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Docker ===
# We commit docker-compose.yml but not local volume data
docker-volumes/
*.dockerignore.local

# === Editors & OS ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# === Database dumps & local data ===
*.sql
*.dump
*.sqlite
*.sqlite3
*.db
data/
backups/

# === ReconMesh-specific ===
# Cached threat feed data — don't ship potentially sensitive feed contents
feed-cache/
ingested/
