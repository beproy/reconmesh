# ReconMesh environment configuration
# Copy this file to .env and fill in real values
# .env is in .gitignore and will NEVER be committed
# .env.example IS committed so other users know what variables to set

# === Database ===
# Will be used in Session 2
POSTGRES_USER=reconmesh
POSTGRES_PASSWORD=changeme_to_a_long_random_string
POSTGRES_DB=reconmesh
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Backend ===
# A long random string used to sign sessions/tokens (generate with: openssl rand -hex 32)
BACKEND_SECRET_KEY=changeme_to_a_long_random_hex_string
BACKEND_PORT=8000

# === Frontend ===
FRONTEND_PORT=3000

# === Optional API keys (none required for MVP, all opt-in) ===
# VIRUSTOTAL_API_KEY=
# SHODAN_API_KEY=
